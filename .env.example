# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme

# --- SQLAlchemy async database URL ---
# Uses the values above. "db" is the Docker Compose service name.
DATABASE_URL=postgresql+asyncpg://app_user:changeme@db:5432/app_db

# --- JWT ---
# Generate a secure secret key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Then paste the output here. Keep it secret!
SECRET_KEY=REPLACE_ME_WITH_A_SECURE_RANDOM_KEY

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
